# Copy to .env.docker and fill in real values (gitignored)
# DATABASE_URL: use Railway public URL for real data, or postgresql://postgres:postgres@db:5432/dokument_hub for local db
# APP_USERS_JSON: set in docker-compose.yml ($$ escaping for bcrypt hash)

SIGNATURE_SENDER_EMAIL=froyland@proaktiv.no
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS="[https://proaktiv-dokument-hub.vercel.app]"
APP_ENV=development
LOG_LEVEL=INFO
PLATFORM=railway
SECRET_KEY=your-secret-key

# Database - replace with actual Railway public URL for real data
DATABASE_URL=postgresql://postgres:PASSWORD@shuttle.proxy.rlwy.net:PORT/railway

# Vitec Hub
VITEC_HUB_BASE_URL=https://hub.megler.vitec.net
VITEC_HUB_PRODUCT_LOGIN=Prod_287_ProaktivGruppenAS
VITEC_HUB_ACCESS_KEY=your-access-key
VITEC_INSTALLATION_ID=MSPROA

# Entra ID (optional)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_ORGANIZATION=

# Firecrawl (optional)
FIRECRAWL_API_KEY=
