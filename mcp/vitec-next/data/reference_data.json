  "layout_partials": [
    {
      "name": "Vitec Bunntekst (Standard Footer)",
      "merge_fields": [
        "meglerkontor.adresse",
        "meglerkontor.besoksadresse",
        "meglerkontor.besokspostnr",
        "meglerkontor.besokspoststed",
        "meglerkontor.epost",
        "meglerkontor.juridisknavn",
        "meglerkontor.orgnr",
        "meglerkontor.postnr",
        "meglerkontor.poststed",
        "meglerkontor.tlf"
      ],
      "code_blocks": [
        "<span vitec-template=\"resource:Vitec Stilark\">&nbsp;</span>",
        "<div id=\"vitecTemplate\">\n  <span vitec-template=\"resource:Vitec Stilark\">&nbsp;</span>\n  <table cellspacing=\"0\" style=\"border-collapse:collapse; table-layout:fixed; width:21cm\">\n    <tbody>\n      <tr>\n        <td colspan=\"30\" style=\"padding-left:1cm\">\n          <small>[[meglerkontor.juridisknavn]]</small>\n        </td>\n        <td colspan=\"40\" style=\"text-align:center\">\n          <small>[[meglerkontor.adresse]], [[meglerkontor.postnr]] [[meglerkontor.poststed]]</small>\n        </td>\n        <td colspan=\"30\" style=\"padding-right:1cm; text-align:right\">\n          <small>Tlf: [[meglerkontor.tlf]]</small>\n        </td>\n      </tr>\n      <tr>\n        <td colspan=\"30\" style=\"padding-left:1cm\">\n          <small>Org.nr: [[meglerkontor.orgnr]]</small>\n        </td>\n        <td colspan=\"40\" style=\"text-align:center\">\n          <small>Besøksadresse: [[meglerkontor.besoksadresse]], [[meglerkontor.besokspostnr]] [[meglerkontor.besokspoststed]]</small>\n        </td>\n        <td colspan=\"30\" style=\"padding-right:1cm; text-align:right\">\n          <small>[[meglerkontor.epost]]</small>\n        </td>\n      </tr>\n    </tbody>\n  </table>\n</div>"
      ]
    },
    {
      "name": "Vitec Bunntekst Fremleiekontrakt",
      "merge_fields": [
        "P",
        "p"
      ],
      "code_blocks": [
        "<div id=\"vitecTemplate\">\n  <span vitec-template=\"resource:Vitec Stilark\">&nbsp;</span>\n  <table style=\"height:1.5cm; table-layout:fixed; width:20cm\">\n    <tbody>\n      <tr>\n        <td style=\"font-size:8pt; padding:0.25cm 0.5cm 0.5cm 2cm; vertical-align:bottom\">\n          <div style=\"border-top:solid 1px #000000; text-align:center; width:3cm\">Utleier</div>\n        </td>\n        <td style=\"font-size:8pt; padding:0.25cm 0.5cm 0.5cm 2cm; vertical-align:bottom\">\n          <div style=\"border-top:solid 1px #000000; text-align:center; width:3cm\">Fremleier</div>\n        </td>\n        <td style=\"font-size:8pt; padding:0.25cm 0cm 0.5cm 0.5cm; text-align:right; vertical-align:bottom\">\n          <div style=\"border-top:solid 1px #000000; float:right; text-align:center; width:3cm\">Fremleietaker</div>\n        </td>\n        <td style=\"padding:0.5cm; text-align:center\">\n          <span style=\"font-size:8pt\">side [[p]] av [[P]]</span>\n        </td>\n      </tr>\n    </tbody>\n  </table>\n</div>",
        "<div style=\"border-top:solid 1px #000000; text-align:center; width:3cm\">\n  Signatur-label\n</div>"
      ]
    },
    {
      "name": "Vitec Bunntekst Kontrakt",
      "merge_fields": [
        "P",
        "p"
      ],
      "code_blocks": [
        "<div id=\"vitecTemplate\">\n  <span vitec-template=\"resource:Vitec Stilark\">&nbsp;</span>\n  <table style=\"height:1.5cm; table-layout:fixed; width:20cm\">\n    <tbody>\n      <tr>\n        <td style=\"font-size:8pt; padding:0.25cm 0.5cm 0.5cm 2cm; vertical-align:bottom\">\n          <div style=\"border-top:solid 1px #000000; text-align:center; width:3cm\">\n            <span vitec-if=\"!Model.oppdrag.type.Contains(&quot;tleie&quot;)\">Selger</span>\n            <span vitec-if=\"Model.oppdrag.type.Contains(&quot;tleie&quot;)\">Utleier</span>\n          </div>\n        </td>\n        <td style=\"padding:0.5cm; text-align:center\">\n          <span style=\"font-size:8pt\">side [[p]] av [[P]]</span>\n        </td>\n        <td style=\"font-size:8pt; padding:0.25cm 1cm 0.5cm 0.5cm; text-align:right; vertical-align:bottom\">\n          <div style=\"border-top:solid 1px #000000; float:right; text-align:center; width:3cm\">\n            <span vitec-if=\"!Model.oppdrag.type.Contains(&quot;tleie&quot;)\">Kjøper</span>\n            <span vitec-if=\"Model.oppdrag.type.Contains(&quot;tleie&quot;)\">Leietaker</span>\n          </div>\n        </td>\n      </tr>\n    </tbody>\n  </table>\n</div>"
      ]
    },
    {
      "name": "Vitec Bunntekst Sidetall",
      "merge_fields": [
        "P",
        "p"
      ],
      "code_blocks": [
        "<style type=\"text/css\">\n@import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;700&display=swap');\n\n#vitecTemplate table {\n    margin: 0;\n    padding: 0;\n    width: 100%;\n    height: 1.5cm;\n    border-collapse: collapse;\n    font-family: 'Open sans', sans-serif;\n    font-size: 8pt;\n    line-height: 10pt;\n    table-layout: fixed;\n}\n\n#vitecTemplate tr td {\n    vertical-align: middle;\n    text-align: center;\n    font-family: 'Open sans', sans-serif;\n    font-size: 8pt;\n    line-height: 9pt;\n}\n</style>\n\n<div id=\"vitecTemplate\">\n  <table>\n    <tbody>\n      <tr>\n        <td>[[p]] av [[P]]</td>\n      </tr>\n    </tbody>\n  </table>\n</div>"
      ]
    },
    {
      "name": "Vitec Bunntekst Sikring (Pantedokument)",
      "merge_fields": [
        "P",
        "p"
      ],
      "code_blocks": [
        "<style type=\"text/css\">\n#vitecTemplate td[data-label] {\n    padding: 16px 2px 4px 3px;\n    position: relative;\n}\n\n#vitecTemplate td[data-label]:before {\n    content: attr(data-label);\n    text-align: left;\n    color: #333;\n    font-size: 7pt;\n    line-height: 8pt;\n    text-transform: uppercase;\n    display: block;\n    position: absolute;\n    top: 1px;\n}\n\n#vitecTemplate tr th,\n#vitecTemplate tr td {\n    vertical-align: middle;\n    border: solid 1px #000;\n    font-family: 'Open sans', sans-serif;\n    font-size: 8pt;\n    line-height: 9pt;\n}\n\n#vitecTemplate td.no-border {\n    border: none;\n}\n</style>\n\n<div id=\"vitecTemplate\" style=\"padding-left:1cm; padding-right:1cm\">\n  <table>\n    <tbody>\n      <tr>\n        <td colspan=\"25\" data-label=\"Dato\">&nbsp;</td>\n        <td colspan=\"75\" data-label=\"Pantsetters underskrift\">&nbsp;</td>\n      </tr>\n      <tr contenteditable=\"false\">\n        <td class=\"no-border\" colspan=\"20\">\n          <small>Statens kartverk - rev 01/19</small>\n        </td>\n        <td class=\"no-border\" colspan=\"60\" style=\"text-align:center\">\n          <small>Pantedokument - Panterett i \n            <span vitec-if=\"Model.eiendom.eieform != &quot;Andel&quot;\">fast eiendom</span>\n            <span vitec-if=\"Model.eiendom.eieform == &quot;Andel&quot;\">andel i borettslag</span>\n          </small>\n        </td>\n        <td class=\"no-border\" colspan=\"20\" style=\"text-align:right\">\n          <small>Side [[p]] av [[P]]</small>\n        </td>\n      </tr>\n    </tbody>\n  </table>\n</div>",
        "<td data-label=\"Feltlabel\">&nbsp;</td>"
      ]
    },
    {
      "name": "Vitec Bunntekst Skjøte",
      "merge_fields": [
        "P",
        "p"
      ],
      "code_blocks": [
        "<div id=\"vitecTemplate\" style=\"padding-left:0.5cm; padding-right:0.5cm\">\n  <table>\n    <tbody>\n      <tr>\n        <td colspan=\"25\" data-label=\"Dato\">&nbsp;</td>\n        <td colspan=\"75\" data-label=\"Utstederens underskrift\">&nbsp;</td>\n      </tr>\n      <tr contenteditable=\"false\">\n        <td class=\"no-border\" colspan=\"20\"><small>GA-5400 B</small></td>\n        <td class=\"no-border\" colspan=\"60\" style=\"text-align:center\"><small>Skjøte</small></td>\n        <td class=\"no-border\" colspan=\"20\" style=\"text-align:right\"><small>Side [[p]] av [[P]]</small></td>\n      </tr>\n    </tbody>\n  </table>\n</div>"
      ]
    },
